config **.cli[*].app[0].idleInterval truncnormal(3600s,1200s)
config **.cli[*].app[0].reconnectInterval 30s
config **.srv.numApps 1
config **.srv.app[*].typename TcpGenericServerApp
config **.srv.app[0].localAddress "\"\""
config **.srv.app[0].localPort 1000
config **.srv.app[0].replyDelay 0s
