config description "TCP apps via IPv6 over PPP network"
config extends "TCP_APP, PPP_net"
config **.cli[*].numApps 1
config **.cli[*].app[*].typename TelnetApp
config **.cli[*].app[0].localAddress "\"\""
config **.cli[*].app[0].localPort -1
