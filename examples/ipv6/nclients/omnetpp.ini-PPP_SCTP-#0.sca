config output-vector-file results/omnetpp.ini-PPP_SCTP-#0.vec
config output-vector-precision 17
config record-eventlog false
config sim-time-limit 100s
config sim-time-limit 100s
config description "SCTP apps via IPv6 over PPP network"
config extends "SCTP_APP, PPP_net"
config description "SCTP apps via IPv6"
config *.cli[*].hasSctp true
config *.srv.hasSctp true
config **.cli[*].numApps 1
config **.cli[*].app[*].typename SctpClient
config **.cli[*].app[0].localAddress "\"\""
config **.cli[*].app[0].connectAddress "\"srv\""
config **.cli[*].app[0].connectPort 1000
config **.cli[*].app[0].startTime "5s + exponential(4s)"
config **.cli[*].app[0].numRequestsPerSession 2
config **.cli[*].app[0].requestLength 1000
config **.cli[*].app[0].thinkTime exponential(1s)
config **.cli[*].app[0].queueSize 0
config **.srv.numApps 1
config **.srv.app[*].typename SctpServer
config **.srv.app[*].localAddress "\"\""
config **.srv.app[0].localPort 1000
config **.srv.app[0].numPacketsToReceivePerClient 2
config description "PPP network"
config network NClientsPPP
config **.ppp[*].queue.typename DropTailQueue
config **.ppp[*].queue.packetCapacity 10
config *.n 4

