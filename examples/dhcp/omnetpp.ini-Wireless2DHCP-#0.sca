config **.param-recording false
config image-path /home/zoli/Projects/OMNET/inet/images
config output-scalar-file results/omnetpp.ini-Wireless2DHCP-#0.sca
config output-scalar-precision 17
config output-vector-file results/omnetpp.ini-Wireless2DHCP-#0.vec
config output-vector-precision 17
config record-eventlog false
config sim-time-limit 500s
config description "Wireless hosts configured via DHCP"
config network WirelessNetWith2DHCP
config extends _Wireless
config **.numHosts 1
config **.wlan[*].radio.transmitter.power 2mW
config **.configurator.config "xml(\"     <config>         <interface hosts='dhcpServer1' names='eth0' address='192.168.1.1' netmask='255.255.255.0'/>         <interface hosts='dhcpServer2' names='eth0' address='192.168.2.1' netmask='255.255.255.0'/>         <interface among='server dhcpServer1' address='192.168.3.x' netmask='255.255.255.0'/>         <interface among='server dhcpServer2' address='192.168.4.x' netmask='255.255.255.0'/>         <wireless hosts='client'/>         <route hosts='server' destination='192.168.1.0' netmask='255.255.255.0' gateway='dhcpServer1' />         <route hosts='server' destination='192.168.2.0' netmask='255.255.255.0' gateway='dhcpServer2' />     </config>     \")"
config **.client.numApps 2
config **.client.app[0].typename DhcpClient
config **.client.app[1].typename PingApp
config **.client.app[1].destAddr "\"server\""
config **.client.app[1].startTime 3s
config **.client.mobility.typename RectangleMobility
config **.client.mobility.constraintAreaMinX 60m
config **.client.mobility.constraintAreaMinY 100m
config **.client.mobility.constraintAreaMaxX 540m
config **.client.mobility.constraintAreaMaxY 150m
config **.client.mobility.startPos 0
config **.client.mobility.speed 20mps
config **.mobility.constraintAreaMinX 0m
config **.mobility.constraintAreaMinY 100m
config **.mobility.constraintAreaMinZ 0m
config **.mobility.constraintAreaMaxX 600m
config **.mobility.constraintAreaMaxY 450m
config **.mobility.constraintAreaMaxZ 0m
config **.dhcpServer1.numApps 1
config **.dhcpServer1.app[0].typename DhcpServer
config **.dhcpServer1.app[0].interface "\"eth0\""
config **.dhcpServer1.app[0].numReservedAddresses 10
config **.dhcpServer1.app[0].maxNumClients 100
config **.dhcpServer1.app[0].leaseTime 100s
config **.dhcpServer2.numApps 1
config **.dhcpServer2.app[0].typename DhcpServer
config **.dhcpServer2.app[0].interface "\"eth0\""
config **.dhcpServer2.app[0].numReservedAddresses 10
config **.dhcpServer2.app[0].maxNumClients 100
config **.dhcpServer2.app[0].leaseTime 100s
config **.dhcpServer*.forwarding true
config description "common base for wireless dhcp simulations"
config *.visualizer.dataLinkVisualizer.packetFilter "\"ping*\""
config *.visualizer.dataLinkVisualizer.lineStyle "\"dotted\""
config **.radio.displayCommunicationRange true
config sim-time-limit 500s

