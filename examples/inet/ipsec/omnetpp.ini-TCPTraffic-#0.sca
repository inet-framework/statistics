config **.param-recording false
config image-path /home/zoli/Projects/OMNET/inet/images
config output-scalar-file results/omnetpp.ini-TCPTraffic-#0.sca
config output-scalar-precision 17
config output-vector-file results/omnetpp.ini-TCPTraffic-#0.vec
config output-vector-precision 17
config record-eventlog false
config sim-time-limit 200s
config description "IPsec with TCP traffic"
config sim-time-limit 200s
config **.numApps 3
config **.client*.app[*].typename TcpSessionApp
config **.client*.app[*].active true
config **.client*.app[0].localPort 1000
config **.client*.app[1].localPort 1001
config **.client*.app[2].localPort 1002
config **.client*.app[*].connectAddress "\"server\""
config **.client*.app[0].connectPort 2000
config **.client*.app[1].connectPort 2001
config **.client*.app[2].connectPort 2002
config **.client*.app[*].tOpen 0.2s
config **.client*.app[*].tSend 0.4s
config **.client*.app[*].sendBytes 1000000B
config **.client*.app[*].sendScript "\"\""
config **.client*.app[*].tClose 25s
config **.server*.app[*].typename TcpEchoApp
config **.server*.app[0].localPort 2000
config **.server*.app[1].localPort 2001
config **.server*.app[2].localPort 2002
config **.server*.app[0].echoFactor 2.0
config **.server*.app[0].echoDelay 0s
config network TwoHosts
config **.ppp[*].queueType "\"DropTailQueue\""
config **.ppp[*].queue.frameCapacity 10
config *.configurator.config "xml(\"<config><interface hosts='*' address='192.168.1.x' netmask='255.255.255.0'/></config>\")"
config **.client*.**.hasIpsec true
config **.server.**.hasIpsec true
config **.client1.**spdConfig "xmldoc(\"ipsecConfig.xml\", \"ipsecConfig/Devices/Device[@id='client1']/\")"
config **.server.**spdConfig "xmldoc(\"ipsecConfig.xml\", \"ipsecConfig/Devices/Device[@id='server']/\")"
config **.ipsec.ahProtectOutDelay 7us
config **.ipsec.ahProtectInDelay 9us
config **.ipsec.espProtectOutDelay 7us
config **.ipsec.espProtectInDelay 9us

