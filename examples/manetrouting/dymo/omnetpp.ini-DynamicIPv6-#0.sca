config *.ipv6Configurator.config "xml(\"<config><interface hosts='*' names='wlan*' maxRtrAdvInterval='0.07' minRtrAdvInterval='0.03'/></config>\")"
config network DYMONetwork
config *.numHosts 20
config num-rngs 3
config **.mobility.rng-0 1
config **.wlan[*].mac.rng-0 2
config **.host[*].mobility.typename StationaryMobility
