config record-eventlog false
config sim-time-limit 22s
config sim-time-limit 22s
config extends _Dynamic,_IPv6
config description "some nodes are shut down and restarted trigger route changes"
config *.host[*].hasStatus true
config *.host[0].status.initialStatus "\"down\""
config *.scenarioManager.script "xmldoc(\"scenario.xml\")"
config description "base for Ipv6"
config **.host[*].hasIpv6 true
config **.dymo.networkProtocolModule "\"^.ipv6.ipv6\""
config **.dymo.routingTableModule "\"^.ipv6.routingTable\""
