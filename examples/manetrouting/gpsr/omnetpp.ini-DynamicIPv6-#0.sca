config sim-time-limit 20s
config extends "Random, _Dynamic, _IPv6"
config **.hasIpv4 false
config **.hasIpv6 true
config network GPSRNetworkRandom
config *.numHosts 20
config **.host[*].mobility.typename StationaryMobility
config *.host[*].numApps 1
config *.host[*].app[0].typename PingApp
config *.host[*].app[0].startTime uniform(1s,5s)
config *.host[*].app[0].printPing true
config description "some nodes are shut down and restarted to trigger route changes"
config *.host[*].hasStatus true
config *.host[0].status.initialStatus "\"down\""
config *.scenarioManager.script "xmldoc(\"scenario.xml\")"
config description "base config for Ipv6"
config **.gpsr.networkProtocolModule "\"^.ipv6.ipv6\""
config **.gpsr.routingTableModule "\"^.ipv6.routingTable\""
config *.hasIpv6Configurator true
config **.ipv6.configurator.networkConfiguratorModule "\"ipv6Configurator\""
config *.ipv6Configurator.config "xml(\"<config><interface hosts='*' prefix='2001:db8::/64'/></config>\")"
config **.ipv6.ipv6.sendRedirects false
config *.host[0].app[0].destAddr "\"host[1](ipv6)\""
config num-rngs 3
config **.mobility.rng-0 1
config **.wlan[*].mac.rng-0 2
config **.mobility.constraintAreaMinZ 0m
config **.mobility.constraintAreaMaxZ 0m
