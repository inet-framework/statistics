config *.configurator.config "xml(\"<config>                                 <interface among='RA host0' address='10.0.x.x' netmask='255.x.x.x'/>                                 <interface among='RB host1' address='20.0.x.x' netmask='255.x.x.x'/>                                 <interface among='RA R RB' address='192.168.x.x' netmask='255.x.x.x'/>                                 <route hosts='RA' destination='192.168.0.5' netmask='255.255.255.255' interface='eth0' />                                 <route hosts='RB' destination='192.168.0.1' netmask='255.255.255.255' interface='eth0' />                                 <route hosts='host*' destination='*' netmask='0.0.0.0' interface='eth0' />                              </config>\")"
config *.RA.hasBgp true
config *.RB.hasBgp true
config *.R*.bgp.bgpConfig "xmldoc(\"BGPConfig_MultiHopEBGP.xml\")"
config sim-time-limit 1000s
config *.pcapRecorder.moduleNamePatterns "\".^\""
config **.checksumMode "\"computed\""
config **.fcsMode "\"computed\""
config **.ip.procDelay 10us
config **.eth[*].queue.typename EthernetQosQueue
config **.eth[*].queue.dataQueue.typename DropTailQueue
config **.tcp.mss 1024
config **.tcp.advertisedWindow 14336
config **.tcp.tcpAlgorithmClass "\"TcpReno\""
config *.R*.ipv4.routingTable.useAdminDist true
config *.configurator.config "xml(\"<config>                                 <interface hosts='**' address='10.x.x.x' netmask='255.x.x.x'/>                                 <route hosts='host*' destination='*' netmask='0.0.0.0' interface='eth0' />                              </config>\")"
config *.configurator.addStaticRoutes false
config *.host0.numApps 1
config *.host0.app[0].typename PingApp
config *.host0.app[0].destAddr "\"host1\""
config *.host0.app[0].startTime 100s
