config description "BGP Scenario with E-BGP session only"
config network BGP_Topology_1
config *.routingTableRecorder.logfile "\"step2.rt\""
config *.pcapRecorder.pcapFile "\"step2.pcap\""
config *.configurator.config "xml(\"<config>                                 <interface hosts='RA4' names='eth0' address='192.168.x.x' netmask='255.x.x.x'/>                                 <interface hosts='RB1' names='eth2' address='192.168.x.x' netmask='255.x.x.x'/>                                                                 <interface among='host0 RA*' address='10.x.x.x' netmask='255.x.x.x'/>                                 <interface hosts='RA*' address='10.x.x.x' netmask='255.x.x.x'/>                                                                 <interface among='host1 RB*' address='20.x.x.x' netmask='255.x.x.x'/>                                 <interface hosts='RB*' address='20.x.x.x' netmask='255.x.x.x'/>                                                                 <route hosts='RA4' destination='*' netmask='0.0.0.0' interface='eth0' />                                 <route hosts='RB1' destination='*' netmask='0.0.0.0' interface='eth2' />                                 <route hosts='host*' destination='*' netmask='0.0.0.0' interface='eth0' />                              </config>\")"
config *.R*.hasOspf true
config *.R*.ospf.ospfConfig "xmldoc(\"OSPFConfig_EBGP.xml\")"
config *.RA4.ipv4.routingTable.routerId "\"10.0.0.5\""
config *.RB1.ipv4.routingTable.routerId "\"20.0.0.18\""
config *.RA4.hasBgp true
config *.RB1.hasBgp true
config *.R*.bgp.bgpConfig "xmldoc(\"BGPConfig_EBGP.xml\")"
config *.RA4.bgp.redistributeOspf "\"O IA\""
config *.RB1.bgp.redistributeOspf "\"O IA\""
config sim-time-limit 1000s
config *.pcapRecorder.moduleNamePatterns "\".^\""
config **.checksumMode "\"computed\""
config **.fcsMode "\"computed\""
config **.ip.procDelay 10us
config **.eth[*].queue.typename EthernetQosQueue
config **.eth[*].queue.dataQueue.typename DropTailQueue
config **.tcp.mss 1024
config **.tcp.advertisedWindow 14336
config **.tcp.tcpAlgorithmClass "\"TcpReno\""
config *.R*.ipv4.routingTable.useAdminDist true
config *.configurator.config "xml(\"<config>                                 <interface hosts='**' address='10.x.x.x' netmask='255.x.x.x'/>                                 <route hosts='host*' destination='*' netmask='0.0.0.0' interface='eth0' />                              </config>\")"
config *.configurator.addStaticRoutes false
config *.host0.numApps 1
config *.host0.app[0].typename PingApp
config *.host0.app[0].destAddr "\"host1\""
config *.host0.app[0].startTime 100s
config *.visualizer.numRoutingTableVisualizers 2
config *.visualizer.interfaceTableVisualizer[0].displayInterfaceTables true
config *.visualizer.routingTableVisualizer[*].displayRoutingTables true
