config **.param-recording false
config image-path /home/levy/workspace/inet/images
config output-scalar-file results/omnetpp.ini-ConstantClockDriftOutOfBandSync-#0.sca
config output-vector-file results/omnetpp.ini-ConstantClockDriftOutOfBandSync-#0.vec
config sim-time-limit 0.1s
config description "Clocks are periodically synchronized out-of-band, without a real protocol. Clocks use constant drift oscillators."
config extends "OutOfBandSyncBase, ConstantClockDrift"
config description "Base config for out-of-band synchronization"
config *.source*.clock.typename SettableClock
config *.source*.clock.defaultOverdueClockEventHandlingMode "\"execute\""
config *.source*.numApps 2
config *.source*.app[1].typename SimpleClockSynchronizer
config *.source*.app[1].masterClockModule "\"^.^.switch1.clock\""
config *.source*.app[1].slaveClockModule "\"^.clock\""
config *.source*.app[1].synchronizationInterval 500us
config *.source*.app[1].synchronizationClockTimeError "uniform(-10ns, 10ns)"
config description "Clocks with constant drift rate diverge over time"
config *.source*.clock.typename OscillatorBasedClock
config *.source*.clock.oscillator.typename ConstantDriftOscillator
config *.source1.clock.oscillator.driftRate 500ppm
config *.source2.clock.oscillator.driftRate -400ppm
config *.source*.app[0].source.clockModule "\"^.^.clock\""
config *.switch1.clock.typename OscillatorBasedClock
config *.switch1.clock.oscillator.typename ConstantDriftOscillator
config *.switch1.clock.oscillator.driftRate 300ppm
config *.switch1.eth[0].macLayer.queue.gate[*].clockModule "\"^.^.^.^.clock\""
config network ClockDriftShowcase
config sim-time-limit 0.1s
config *.*.ethernet.typename EthernetLayer
config **.hasGlobalArp true
config *.source*.numApps 1
config *.source*.app[*].typename UdpSourceApp
config *.source*.app[0].source.packetLength 800B
config *.source*.app[0].source.productionInterval 20us
config *.source*.app[0].io.destPort 1000
config *.source1.app[0].io.destAddress "\"sink1\""
config *.source1.app[0].source.packetNameFormat "\"source1-%c\""
config *.source2.app[0].io.destAddress "\"sink2\""
config *.source2.app[0].source.initialProductionOffset 10us
config *.source2.app[0].source.packetNameFormat "\"source2-%c\""
config *.sink*.numApps 1
config *.sink*.app[*].typename UdpSinkApp
config *.sink*.app[0].io.localPort 1000
config **.displayGateSchedules true
config **.gateScheduleVisualizer.height 16
config *.*.eth[*].typename LayeredEthernetInterface
config *.*.eth[*].bitrate 1Gbps
config *.switch1.eth[0].macLayer.queue.typename GatingPriorityQueue
config *.switch1.eth[0].macLayer.queue.numQueues 2
config *.switch1.eth[0].macLayer.queue.classifier.typename ContentBasedClassifier
config *.switch1.eth[0].macLayer.queue.classifier.packetFilters "[\"source1*\", \"source2*\"]"
config *.switch1.eth[0].macLayer.queue.queue[*].typename DropTailQueue
config *.switch1.eth[0].macLayer.queue.gate[*].initiallyOpen false
config *.switch1.eth[0].macLayer.queue.gate[*].durations "[10us, 10us]"
config *.switch1.eth[0].macLayer.queue.gate[0].offset 3.118us
config *.switch1.eth[0].macLayer.queue.gate[1].offset 13.118us
config **.clock.useFutureEventSet false
config **.oscillator.nominalTickLength 1us

