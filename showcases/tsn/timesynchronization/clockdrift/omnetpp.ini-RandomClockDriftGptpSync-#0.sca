config *.sink*.app[0].io.localPort 1000
config **.displayGateSchedules true
config **.gateScheduleVisualizer.height 16
config *.*.eth[*].typename LayeredEthernetInterface
config *.*.eth[*].bitrate 1Gbps
config *.switch1.eth[0].macLayer.queue.typename GatingPriorityQueue
config *.switch1.eth[0].macLayer.queue.numQueues 2
config *.switch1.eth[0].macLayer.queue.classifier.typename ContentBasedClassifier
config *.switch1.eth[0].macLayer.queue.classifier.packetFilters "[\"source1*\", \"source2*\"]"
